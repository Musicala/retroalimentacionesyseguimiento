rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // APP DE ACTAS (existente) — copiado tal cual de las reglas previas.
    // No modificar: garantiza que la app de actas siga funcionando igual.
    // =====================================================================

    function hasOnlyMeetingKeys(data) {
      return data.keys().hasOnly([
        'status',
        'template',
        'dateISO',
        'periodLabel',
        'employeeName',
        'employeeKey',
        'role',
        'area',
        'attendees',
        'attendeesText',
        'place',
        'meetingKind',
        'objective',
        'meetingFrame',
        'previousActionsReview',
        'sectionConfig',
        'sections',
        'actionItems',
        'createdBy',
        'updatedBy',
        'finalizedAt',
        'finalizedBy',
        'createdAt',
        'updatedAt'
      ]);
    }

    function isValidMeeting(data) {
      return hasOnlyMeetingKeys(data)
        && (!('status' in data) || data.status in ['draft', 'final'])
        && (!('template' in data) || data.template in ['admin', 'docente'])
        && (!('dateISO' in data) || data.dateISO is string)
        && (!('periodLabel' in data) || data.periodLabel is string)
        && (!('employeeName' in data) || data.employeeName is string)
        && (!('employeeKey' in data) || data.employeeKey is string)
        && (!('role' in data) || data.role is string)
        && (!('area' in data) || data.area is string)
        && (!('attendeesText' in data) || data.attendeesText is string)
        && (!('place' in data) || data.place is string)
        && (!('meetingKind' in data) || data.meetingKind is string)
        && (!('objective' in data) || data.objective is string)
        && (!('meetingFrame' in data) || data.meetingFrame is string)
        && (!('previousActionsReview' in data) || data.previousActionsReview is list)
        && (!('attendees' in data) || data.attendees is list)
        && (!('sectionConfig' in data) || data.sectionConfig is list)
        && (!('sections' in data) || data.sections is map)
        && (!('actionItems' in data) || data.actionItems is list)
        && (!('createdBy' in data) || data.createdBy is string)
        && (!('updatedBy' in data) || data.updatedBy is string)
        && (!('finalizedAt' in data) || data.finalizedAt is string)
        && (!('finalizedBy' in data) || data.finalizedBy is string)
        && (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt == request.time)
        && (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    function isAllowedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
          'alekcaballeromusic@gmail.com',
          'catalina.medina.leal@gmail.com'
        ];
    }

    match /meetings/{meetingId} {
      allow read: if isAllowedUser();
      allow create: if isAllowedUser() && isValidMeeting(request.resource.data);
      allow update: if isAllowedUser()
        && isValidMeeting(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAllowedUser();
    }

    // =====================================================================
    // APP DE RETROALIMENTACIONES (nueva) — colecciones separadas.
    // =====================================================================

    function fbSignedIn() {
      return request.auth != null
        && request.auth.token.email_verified == true;
    }

    function fbEmail() {
      return request.auth.token.email.lower();
    }

    function fbIsAdmin() {
      return fbSignedIn() && fbEmail() in [
        'alekcaballeromusic@gmail.com',
        'catalina.medina.leal@gmail.com'
      ];
    }

    // Usuario autorizado: su correo (en minúsculas) existe como documento
    // en authorizedFeedbackUsers y está activo.
    function fbIsAuthorizedUser() {
      return fbSignedIn()
        && exists(/databases/$(database)/documents/authorizedFeedbackUsers/$(fbEmail()))
        && get(/databases/$(database)/documents/authorizedFeedbackUsers/$(fbEmail())).data.active != false;
    }

    function fbCanUseApp() {
      return fbIsAdmin() || fbIsAuthorizedUser();
    }

    // Entradas: usuarios autorizados solo pueden CREAR (no leer, ni listar,
    // ni modificar). Solo admins pueden leer, actualizar y eliminar.
    match /feedbackEntries/{entryId} {
      allow create: if fbCanUseApp()
        && request.resource.data.createdByEmail == fbEmail()
        && request.resource.data.status == 'pendiente';
      allow read, update, delete: if fbIsAdmin();
    }

    // Personas: lectura para usuarios del canal (necesaria para el
    // formulario); escritura solo admins.
    match /people/{personId} {
      allow read: if fbCanUseApp();
      allow write: if fbIsAdmin();
    }

    // Correos autorizados: cada usuario puede leer ÚNICAMENTE su propio
    // documento (para verificar su acceso). Solo admins gestionan la lista.
    match /authorizedFeedbackUsers/{email} {
      allow get: if fbIsAdmin() || (fbSignedIn() && email == fbEmail());
      allow list: if fbIsAdmin();
      allow write: if fbIsAdmin();
    }

    // Configuración de campos: lectura para usuarios del canal,
    // escritura solo admins.
    match /feedbackFields/{docId} {
      allow read: if fbCanUseApp();
      allow write: if fbIsAdmin();
    }

    // Configuración general: lectura para usuarios del canal,
    // escritura solo admins.
    match /feedbackSettings/{docId} {
      allow read: if fbCanUseApp();
      allow write: if fbIsAdmin();
    }

    // Todo lo demás queda bloqueado (igual que en las reglas originales).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
